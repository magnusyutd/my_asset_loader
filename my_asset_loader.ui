  <property name="styleSheet">
   <string notr="true">/* Main Window and Container - Deepened to #2b2b2b */
QWidget {
    background-color: #2b2b2b;
    color: #e0e0e0;
    font-family: &quot;Inter&quot;, &quot;Segoe UI&quot;, sans-serif;
    font-size: 12px;
}

/* TreeView / Content Browser Area - High Contrast Dark */
QTreeView, QListView, QTableWidget {
    background-color: #1e1e1e;
    border: 1px solid #3f3f3f;
    alternate-background-color: #252525;
    /* This ensures the selection spans the full width of the row */
    selection-background-color: #4879b2; 
    selection-color: white;
    outline: none;
}

QTreeView::item {
    height: 28px;
    padding-left: 4px;
}

QTreeView::item:hover {
    background-color: #4879b2;
}

QTreeView::item:selected {
    background-color: #4879b2; 
    color: white;
}

QTableWidget::item {
    padding-left: 6px; 
    padding-top: 0px;
    padding-right: 6px; 
    padding-bottom: 0px; 
    margin: 0px;  
    border-bottom: 1px solid #2a2a2a; 
}

/* Headers - Professional Charcoal */
QHeaderView::section {
    background-color: #333333;
    color: #aaaaaa;
    padding: 2px;
    border: 1px solid #252525;
    font-weight: bold;
	text-transform: uppercase;
}

/* Style the sort indicator arrows */
QHeaderView::up-arrow {
    image: url(:/src/img/arrow_up.png);
    width: 10px;
    height: 10px;
    padding-right: 5px;
}

QHeaderView::down-arrow {
    image: url(:/src/img/arrow_down.png);
    width: 10px;
    height: 10px;
    padding-right: 5px;
}

/* Search Bar - Fixed Text Color Visibility */
QLineEdit {
    background-color: #1a1a1a;
    border: 1px solid #3f3f3f;
    border-radius: 10px;
    padding: 4px 10px;
    color: #e0e0e0;
}

QLineEdit &gt; QToolButton {
    qproperty-icon: url(:/src/img/search_close.png);
}

QLineEdit:focus {
    border: 1px solid #4879b2;
}

/* Action Button - The &quot;Gold&quot; Accent */
QPushButton#loadAssetBtn {
    background-color: #d4a017;
    color: #1a1a1a;
    font-weight: bold;
    font-size: 13px;
    border-radius: 4px;
    border: none;
    padding: 12px;
}

QPushButton#loadAssetBtn:hover {
    background-color: #ffbf00;
}

QPushButton#loadAssetBtn:pressed {
    background-color: #b88a12;
}

/* Tabs - Clean &amp; Flat */
QTabWidget::pane {
    border: 1px solid #3f3f3f;
    background-color: #1e1e1e;
    top: -1px;
}

QTabBar::tab {
    background-color: #2b2b2b;
    color: #888888;
    padding: 8px 20px;
    border: 1px solid #3f3f3f;
	border-radius: 5px;
    border-bottom: none;
    margin-right: 1px;
}

QTabBar::tab:selected {
    background-color: #1e1e1e;
    color: #4879b2;
    border-bottom: 2px solid #4879b2;
}

QScrollBar:vertical {
    background: #2b2b2b;
    /* FIX 1: You must specify '1px solid' and a color for borders to work */
    border: 1px solid #2b2b2b; 
    width: 10px;
    margin: 0px;
}

QScrollBar::add-page:vertical, QScrollBar::sub-page:vertical {
    background: none;
}

QScrollBar::handle:vertical {
    background: #444444;
    border: none;
    min-height: 20px;
    border-radius: 4px;
}

/* Keep this to hide the arrow buttons */
QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical {
    height: 0px;
}

QComboBox { 
    border: 1px solid #3f3f3f;
    border-radius: 4px;
    background-color: #1a1a1a; /* Deeper black for input area */
    padding: 4px 5px;
    color: #e0e0e0;
}

QComboBox:hover {
    border: 1px solid #4879b2; /* Modern Blue highlight */
}

QComboBox::drop-down {
    subcontrol-origin: padding;
    subcontrol-position: top right;
    width: 24px;
    border: none;
}

/* Custom Down Arrow (Triangle) if you don't want to rely on an image file */
QComboBox::down-arrow {
    image: url(:/src/img/drop_down.png); /* Keeps your existing image */
    width: 12px;
    height: 12px;
}

QComboBox QAbstractItemView {
    background-color: #1e1e1e;
    border: 1px solid #3f3f3f;
    selection-background-color: #4879b2;
    selection-color: #ffffff;
    outline: none;
}

/* Space out the items in the list */
QComboBox QAbstractItemView::item {
    min-height: 28px;
    padding-left: 10px;
    color: #aaaaaa;
}

QComboBox QAbstractItemView::item:hover {
    background-color: #3d3d3d;
    color: #ffffff;
}</string>
